# --- AI Lab Management System (Client) Configuration ---

# Backend API Configuration
# Use the full URL (e.g., https://api.ailab.org.tr)
VITE_API_BASE_URL=

# Firebase Configuration
# These values can be found in your Firebase Project Settings -> General -> Your Apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Port for local development
# VITE_PORT=5173
